Algoritmo "troca_de_valores"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa Do Santos
// Descriçăo   : Lę dois valores armazenados nas variáveis A e B, e
// Troca os valores entre elas.
// Autor(a)    : Gabriel Regis Silva
// Data atual  : 01/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   A: real
   B: real
   auxiliar: real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite o valor de A: ")
   leia(A)

   escreva("Digite o valor de B: ")
   leia(B)

   auxiliar <- A
   A <- B
   B <- auxiliar

   escreval("Novo valor de A: ", A)
   escreval("Novo valor de B: ", B)

Fimalgoritmo