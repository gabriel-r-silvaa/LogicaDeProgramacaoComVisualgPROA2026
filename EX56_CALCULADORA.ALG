Algoritmo "Ex56_Calculadora"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa Dos Santos
// Descriçăo   : Realiza cálculos básicos (adiçăo, subtraçăo, divisăo ou
// multiplicaçăo) com dois números conforme a opçăo escolhida pelo usuário.
// Autor(a)    : Gabriel Regis Silva
// Data atual  : 17/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   primeiroOperando, segundoOperando, resultado : real
   opcaoOperacao : inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Primeiro numero: ")
   leia(primeiroOperando)
   escreva("Segundo numero: ")
   leia(segundoOperando)
   escreva("Operacao (1=Adicao / 2=Subtracao / 3=Divisao / 4=Multiplicacao): ")
   leia(opcaoOperacao)
   se opcaoOperacao = 1 entao
      resultado <- primeiroOperando + segundoOperando
   senao
      se opcaoOperacao = 2 entao
         resultado <- primeiroOperando - segundoOperando
      senao
         se opcaoOperacao = 3 entao
            resultado <- primeiroOperando / segundoOperando
         senao
            resultado <- primeiroOperando * segundoOperando
         fimse
      fimse
   fimse
   escreval("Resultado: ", resultado)

Fimalgoritmo