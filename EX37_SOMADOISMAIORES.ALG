Algoritmo "Ex37_SomaDoisMaiores"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa Dos Santos
// Descriçăo   : Calcula a soma dos dois maiores valores entre tręs números
// informados.
// Autor(a)    : Gabriel Regis Silva
// Data atual  : 11/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   numeroA, numeroB, numeroC, somaDoisMaiores : real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Valor A: ")
   leia(numeroA)
   escreva("Valor B: ")
   leia(numeroB)
   escreva("Valor C: ")
   leia(numeroC)
   se (numeroA <= numeroB) e (numeroA <= numeroC) entao
      somaDoisMaiores <- numeroB + numeroC
   senao
      se (numeroB <= numeroA) e (numeroB <= numeroC) entao
         somaDoisMaiores <- numeroA + numeroC
      senao
         somaDoisMaiores <- numeroA + numeroB
      fimse
   fimse
   escreval("Soma dos dois maiores: ", somaDoisMaiores)

Fimalgoritmo