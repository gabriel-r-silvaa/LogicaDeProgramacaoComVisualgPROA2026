Algoritmo "Ex49_AprovacaoParabens"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa Dos Santos
// Descriçăo   : Calcula a média do aluno e exibe uma mensagem de aprovaçăo
// quando atingida.
// Autor(a)    : Gabriel Regis Silva
// Data atual  : 11/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   primeiraAvaliacao, segundaAvaliacao, mediaCurso : real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Nota 1: ")
   leia(primeiraAvaliacao)
   escreva("Nota 2: ")
   leia(segundaAvaliacao)
   mediaCurso <- (primeiraAvaliacao + segundaAvaliacao) / 2
   escreval("Media semestral: ", mediaCurso)
   se mediaCurso >= 6.0 entao
      escreval("PARABENS! Voce foi aprovado!")
   fimse

Fimalgoritmo