Algoritmo "Ex51_ValidacaoSenha"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa Dos Santos
// Descriçăo   : Valida uma senha digitada pelo usuário, permitindo acesso
// apenas se o valor for igual a 1234.
// Autor(a)    : Gabriel Regis Silva
// Data atual  : 17/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   senhaDigitada : inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite a senha: ")
   leia(senhaDigitada)
   se senhaDigitada = 1234 entao
      escreval("ACESSO PERMITIDO")
   senao
      escreval("ACESSO NEGADO")
   fimse

Fimalgoritmo