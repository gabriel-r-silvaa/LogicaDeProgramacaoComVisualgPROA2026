Algoritmo "Ex59_TrianguloAngulos"
// Disciplina   : [Lógica de Programaçăo com VisualG]
// Professor   : Jailson Costa Dos Santos
// Descriçăo   : Classifica um triângulo como retângulo, obtusângulo ou
// acutângulo com base nos ângulos informados.
// Autor(a)    : Gabriel Regis Silva
// Data atual  : 11/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   anguloX, anguloY, anguloZ : real

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Angulo 1: ")
   leia(anguloX)
   escreva("Angulo 2: ")
   leia(anguloY)
   escreva("Angulo 3: ")
   leia(anguloZ)
   se (anguloX = 90) ou (anguloY = 90) ou (anguloZ = 90) entao
      escreval("Triangulo Retangulo")
   senao
      se (anguloX > 90) ou (anguloY > 90) ou (anguloZ > 90) entao
         escreval("Triangulo Obtusangulo")
      senao
         escreval("Triangulo Acutangulo")
      fimse
   fimse

Fimalgoritmo